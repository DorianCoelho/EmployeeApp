@page
@model IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Login";
}

<div class="container">
    <div class="row min-vh-100 align-items-center justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    
                    <div class="text-center mb-4">
                        <div class="bg-primary bg-gradient text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="bi bi-person-lock fs-1"></i>
                        </div>
                        <h2 class="fw-bold mt-3">EmployeeApp</h2>
                        <p class="text-muted">Ingresa tus credenciales</p>
                    </div>

                    <form method="post" asp-page="LoginAdmin" asp-antiforgery="true" class="needs-validation" novalidate id="login-form">
                        <div class="form-floating mb-3">
                            <input asp-for="AuthRequest.Email" class="form-control" id="emailaddress" 
                                    autocomplete="username" required />
                            <label asp-for="AuthRequest.Email">Correo Electrónico</label>
                            <span asp-validation-for="AuthRequest.Email" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="AuthRequest.Password" type="password" class="form-control" id="password" 
                                    autocomplete="current-password" required />
                            <label asp-for="AuthRequest.Password">Contraseña</label>
                            <span asp-validation-for="AuthRequest.Password" class="text-danger small"></span>
                        </div>
                        <div class="d-grid">
                            <button class="btn btn-primary btn-lg rounded-pill shadow-sm fw-bold" type="submit">
                                Entrar <i class="bi bi-box-arrow-in-right ms-2"></i>
                            </button>
                        </div>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mt-3 text-decoration-none"></div>
                        
                    </form>

                </div>
                <div class="card-footer bg-light border-0 py-3 text-center rounded-bottom-4">
                    <small class="text-muted">&copy; 2026 Employee Management System</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}