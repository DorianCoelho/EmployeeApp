@page "/employees"

@model EmployeApp.Areas.Employees.Pages.EmployeeList

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold mb-0">Gestión de Empleados</h2>
            <p class="text-muted mb-0">Administra la información y el estado de tu equipo.</p>
        </div>
        <a asp-area="Employees" asp-page="/CreateEmployee" class="btn btn-primary shadow-sm px-4">
            <i class="bi bi-person-plus-fill me-2"></i>Añadir Empleado
        </a>
    </div>
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary text-uppercase small fw-bolder">
                    <tr>
                        <th class="ps-4 py-3">Empleado</th>
                        <th class="py-3">Contacto</th>
                        <th class="py-3">Ubicación</th>
                        <th class="py-3">Nº Cass</th>
                        <th class="text-end pe-4 py-3">Accion</th>
                    </tr>
                    </thead>
                    <tbody class="border-top-0">
                    @foreach (var item in Model.Employees)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div
                                            class="avatar-sm bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold me-3"
                                            style="width: 40px; height: 40px;">
                                        @item.FirstName.Substring(0, 1)@item.LastName.Substring(0, 1)
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark"><a asp-area="Employees" asp-page="EmployeeCard"
                                                                          asp-route-id="@item.Id">@item.FirstName @item.LastName</a>
                                        </div>
                                        <div class="text-muted small">ID: #@item.Id</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="d-flex flex-column">
                                    <span class="small"><i class="bi bi-envelope me-1"></i> @item.Email</span>
                                    <span class="text-muted small"><i
                                                class="bi bi-telephone me-1"></i> @item.PhoneNumber</span>
                                </div>
                            </td>
                            <td>
                                <div class="small">@item.City</div>
                                <div class="text-muted x-small text-truncate"
                                     style="max-width: 150px;">@item.Address</div>
                            </td>
                            <td>
                                    <span
                                            class="badge rounded-pill bg-info-subtle text-info border border-info-subtle px-3">
                                        @item.CassNumber
                                    </span>
                            </td>
                            <td class="text-end pe-4">
                                <a asp-area="Employees" asp-page="/EmployeeCard" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-primary px-3">
                                    <i class="bi bi-eye me-1"></i>Ver
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

