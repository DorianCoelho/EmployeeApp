@page "/employees"

@model EmployeApp.Areas.Employees.Pages.EmployeeList

<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold mb-0">Gestión de Empleados</h2>
            <p class="text-muted mb-0">Administra la información y el estado de tu equipo.</p>
        </div>
        <a asp-area="Employees" asp-page="/CreateEmployee" class="btn btn-primary shadow-sm px-4">
            <i class="bi bi-person-plus-fill me-2"></i>Añadir Empleado
        </a>
    </div>

    <div class="row mb-3">
        <div class="col-md-4">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" class="form-control border-start-0" placeholder="Buscar empleado...">
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary text-uppercase small fw-bolder">
                        <tr>
                            <th class="ps-4 py-3">Empleado</th>
                            <th class="py-3">Contacto</th>
                            <th class="py-3">Ubicación</th>
                            <th class="py-3">Nº Cass</th>
                            <th class="text-end pe-4 py-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var item in Model.Employees)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold me-3" style="width: 40px; height: 40px;">
                                            @item.FirstName.Substring(0, 1)@item.LastName.Substring(0, 1)
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@item.FirstName @item.LastName</div>
                                            <div class="text-muted small">ID: #@item.Id</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="small"><i class="bi bi-envelope me-1"></i> @item.Email</span>
                                        <span class="text-muted small"><i class="bi bi-telephone me-1"></i> @item.PhoneNumber</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="small">@item.City</div>
                                    <div class="text-muted x-small text-truncate" style="max-width: 150px;">@item.Address</div>
                                </td>
                                <td>
                                    <span class="badge rounded-pill bg-info-subtle text-info border border-info-subtle px-3">
                                        @item.CassNumber
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="dropdown">
                                        <button class="btn btn-light btn-sm rounded-pill" type="button" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                            <li><a class="dropdown-item" asp-page="./Details" asp-route-id="@item.Id"><i class="bi bi-eye me-2"></i> Ver detalles</a></li>
                                            <li><a class="dropdown-item text-primary" asp-page="./Edit" asp-route-id="@item.Id"><i class="bi bi-pencil me-2"></i> Editar</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item text-danger" href="#"><i class="bi bi-trash me-2"></i> Eliminar</a></li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

