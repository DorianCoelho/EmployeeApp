@page "/create-employee"
@model EmployeApp.Areas.Employees.Pages.CreateEmployee

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Nuevo Empleado</h4>
        </div>
        <div class="card-body">
            <form method="post">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Employee.FirstName" class="form-label">Nombre</label>
                        <input asp-for="Employee.FirstName" class="form-control" placeholder="Ej: Juan" />
                        <span asp-validation-for="Employee.FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Employee.LastName" class="form-label">Apellido</label>
                        <input asp-for="Employee.LastName" class="form-control" placeholder="Ej: Pérez" />
                        <span asp-validation-for="Employee.LastName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Employee.Email" class="form-label">Correo Electrónico</label>
                    <input asp-for="Employee.Email" type="email" class="form-control" />
                    <span asp-validation-for="Employee.Email" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Employee.PhoneNumber" class="form-label">Teléfono</label>
                        <input asp-for="Employee.PhoneNumber" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Employee.CassNumber" class="form-label">Nº Cass</label>
                        <input asp-for="Employee.CassNumber" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Employee.Address" class="form-label">Dirección</label>
                    <input asp-for="Employee.Address" class="form-control" />
                </div>

                <div class="mb-4">
                    <label asp-for="Employee.City" class="form-label">Ciudad</label>
                    <input asp-for="Employee.City" class="form-control" />
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-success px-4">Guardar Empleado</button>
                </div>
            </form>
        </div>
    </div>
</div>