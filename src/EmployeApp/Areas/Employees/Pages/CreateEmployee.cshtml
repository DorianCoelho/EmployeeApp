@page "/create-employee"
@model EmployeApp.Areas.Employees.Pages.CreateEmployee

<div class="container-xxl mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-9 col-xl-8">

            <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3">
                <div>
                    <h2 class="mb-1">
                        <i class="bi bi-person-plus me-2"></i>Nuevo empleado
                    </h2>
                    <div class="text-muted">
                        Completa los datos del empleado. Los campos obligatorios se validarán automáticamente.
                    </div>
                </div>
            </div>

            <form method="post" class="card shadow-sm border-0">
                <div class="card-body p-4">

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-4"></div>

                    <div class="mb-4">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-person-vcard"></i>
                            <h5 class="mb-0">Datos personales</h5>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Employee.FirstName" class="form-label">Nombre</label>
                                <input asp-for="Employee.FirstName" class="form-control form-control-lg"
                                       placeholder="Ej: Juan"/>
                                <span asp-validation-for="Employee.FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Employee.LastName" class="form-label">Apellidos</label>
                                <input asp-for="Employee.LastName" class="form-control form-control-lg"
                                       placeholder="Ej: Pérez Gómez"/>
                                <span asp-validation-for="Employee.LastName" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4"/>

                    <div class="mb-4">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-envelope-at"></i>
                            <h5 class="mb-0">Contacto</h5>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Employee.Email" class="form-label">Correo electrónico</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                    <input asp-for="Employee.Email" type="email" class="form-control"
                                           placeholder="nombre@correo.com"/>
                                </div>
                                <span asp-validation-for="Employee.Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Employee.PhoneNumber" class="form-label">Teléfono</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                    <input asp-for="Employee.PhoneNumber" class="form-control"
                                           placeholder="Ej: +376 123 456"/>
                                </div>
                                <span asp-validation-for="Employee.PhoneNumber" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4"/>

                    <div class="mb-4">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-shield-check"></i>
                            <h5 class="mb-0">Identificación</h5>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Employee.CassNumber" class="form-label">Nº CASS</label>
                                <input asp-for="Employee.CassNumber" class="form-control form-control-lg"
                                       placeholder="Ej: 000000A"/>
                                <div class="form-text">Formato: 6 números y 1 letra (ej. 000000A).</div>
                                <span asp-validation-for="Employee.CassNumber" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4"/>

                    <div class="mb-2">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-geo-alt"></i>
                            <h5 class="mb-0">Dirección</h5>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-8">
                                <label asp-for="Employee.Address" class="form-label">Dirección</label>
                                <input asp-for="Employee.Address" class="form-control form-control-lg"
                                       placeholder="Calle, número, piso..."/>
                                <span asp-validation-for="Employee.Address" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Employee.City" class="form-label">Ciudad</label>
                                <input asp-for="Employee.City" class="form-control form-control-lg"
                                       placeholder="Ej: Andorra la Vella"/>
                                <span asp-validation-for="Employee.City" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="card-footer bg-white border-0 p-4 pt-0">
                    <div class="d-flex justify-content-end gap-2">
                        <a asp-area="Employees" asp-page="/EmployeeList" class="btn btn-outline-secondary px-4">
                            Cancelar
                        </a>
                        <button type="submit" class="btn btn-success px-4">
                            <i class="bi bi-check2-circle me-1"></i>Guardar
                        </button>
                    </div>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}