@page "/edit-contract/{id:int}"
@model EmployeApp.Areas.Contracts.Pages.EditContract

<div class="container-xxl mt-4">
    <div class="row">
        <div class="col-lg-12">
            <h2 class="mb-3">Editar contrato</h2>
            <p class="text-muted mb-4">
                Solo se permite modificar el salario y las horas semanales.
            </p>

            <div class="mb-3">
                <h5 class="mb-1">Empleado: @Model.Employee.FirstName @Model.Employee.LastName</h5>
                <div class="text-muted">Contrato #@Model.ContractId</div>
            </div>

            <form method="post" class="card shadow-sm">
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="Edit.Id"/>
                    <input type="hidden" asp-for="Edit.EmployeeId"/>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Fecha de inicio</label>
                            <input class="form-control" type="date" asp-for="Edit.StartDate"
                                   readonly="readonly"/>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Fecha de fin</label>
                            <input class="form-control" type="date"
                                   asp-for="Edit.EndDate" readonly="readonly"/>
                            <div class="form-text">Opcional</div>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Puesto de trabajo</label>
                            <input class="form-control" asp-for="Edit.JobTitle" readonly="readonly"/>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Tipo de contrato</label>
                            <input class="form-control" asp-for="Edit.Type" readonly="readonly"/>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Estado del contrato</label>
                            <input class="form-control" asp-for="Edit.Status" readonly="readonly"/>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Tipo de jornada</label>
                            <input class="form-control" asp-for="Edit.WorkDayType" readonly="readonly"/>
                        </div>

                        <hr class="my-2"/>

                        <!-- EDITABLE -->
                        <div class="col-md-6">
                            <label asp-for="Edit.Salary" class="form-label">Salario</label>
                            <input asp-for="Edit.Salary" type="number" step="0.01" min="0"
                                   class="form-control" placeholder="Ej: 1800.00"/>
                            <span asp-validation-for="Edit.Salary" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Edit.WeeklyHours" class="form-label">Horas semanales</label>
                            <input asp-for="Edit.WeeklyHours" type="number" step="0.5" min="0"
                                   class="form-control" placeholder="Ej: 40"/>
                            <span asp-validation-for="Edit.WeeklyHours" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Edit.Reason" class="form-label">Motivo del cambio (opcional)</label>
                            <textarea asp-for="Edit.Reason" class="form-control" rows="2"
                                      placeholder="Ej: Ajuste salarial, cambio de jornada..."></textarea>
                            <span asp-validation-for="Edit.Reason" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="card-footer d-flex gap-2 justify-content-end">
                    <a class="btn btn-outline-secondary"
                       asp-page="/EmployeeCard" asp-area="Employees"
                       asp-route-id="@Model.EmployeeId">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary">
                        Guardar cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}