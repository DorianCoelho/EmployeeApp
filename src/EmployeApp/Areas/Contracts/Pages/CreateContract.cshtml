@page "/create-contract/{employeeId:int}"
@using EmployeeApp.Domain.Core.Entities.Contracts
@model EmployeApp.Areas.Contracts.Pages.CreateContract


<div class="container-xxl mt-4">
    <div class="row">
        <div class="col-lg-12">
            <h2 class="mb-3">Crear contrato</h2>
            <p class="text-muted mb-4">
                Rellena los datos del contrato. La fecha de fin es opcional.
            </p>
            <h5>Empleado selecionado: @Model.Employee.FirstName @Model.Employee.LastName</h5>

            <form method="post" class="card shadow-sm">
                <div class="card-body">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- EmployeeId oculto -->
                    <input type="hidden" asp-for="Contract.EmployeeId"/>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Contract.StartDate" class="form-label">Fecha de Inicio</label>
                            <input asp-for="Contract.StartDate" type="date" class="form-control"/>
                            <span asp-validation-for="Contract.StartDate" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Contract.EndDate" class="form-label">Fecha final</label>
                            <input asp-for="Contract.EndDate" type="date" class="form-control"/>
                            <span asp-validation-for="Contract.EndDate" class="text-danger"></span>
                            <div class="form-text">Opcional</div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Contract.JobTitle" class="form-label">Puesto de trabajo</label>
                            <input asp-for="Contract.JobTitle" class="form-control"
                                   placeholder="Ej: Administrativo, Desarrollador, Responsable de tienda..."/>
                            <span asp-validation-for="Contract.JobTitle" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Contract.Salary" class="form-label">Salario</label>
                            <input asp-for="Contract.Salary" type="number" step="0.01" min="0" class="form-control"
                                   placeholder="Ej: 1800.00"/>
                            <span asp-validation-for="Contract.Salary" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Contract.WeeklyHours" class="form-label">Horas semanales</label>
                            <input asp-for="Contract.WeeklyHours" type="number" step="0.5" min="0" class="form-control"
                                   placeholder="Ej: 40"/>
                            <span asp-validation-for="Contract.WeeklyHours" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Contract.Type" class="form-label">Tipo de contrato</label>
                            <select asp-for="Contract.Type" class="form-select"
                                    asp-items="Html.GetEnumSelectList<ContractType>()">
                                <option value="">-- Selecciona --</option>
                            </select>
                            <span asp-validation-for="Contract.Type" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Contract.Status" class="form-label">Estado del contrato</label>
                            <select asp-for="Contract.Status" class="form-select"
                                    asp-items="Html.GetEnumSelectList<ContractStatus>()">
                                <option value="">-- Selecciona --</option>
                            </select>
                            <span asp-validation-for="Contract.Status" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Contract.WorkDayType" class="form-label">Tipo</label>
                            <select asp-for="Contract.WorkDayType" class="form-select"
                                    asp-items="Html.GetEnumSelectList<WorkDayType>()">
                                <option value="">-- Selecciona --</option>
                            </select>
                            <span asp-validation-for="Contract.WorkDayType" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="card-footer d-flex gap-2 justify-content-end">
                    <a class="btn btn-outline-secondary" asp-page="/EmployeeCard" asp-area="Employees"
                       asp-route-id="@Model.Contract.EmployeeId">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary">
                        Guardar contrato
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}